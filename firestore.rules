rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if requester is admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: read/write own doc; admin read/write all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Kitchens: any authenticated user can read; kitchen owner or admin can write
    match /kitchens/{kitchenId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == kitchenId || isAdmin());

      // Kitchen items: all auth users can read; kitchen owner writes
      match /items/{itemId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == kitchenId || isAdmin());
      }
    }

    // Orders: any authenticated user can create/read
    // Updates allowed for owner, kitchen, assigned rider, or admin
    // Also allow any authenticated rider to claim a waiting_rider order
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.userId    == request.auth.uid ||
        resource.data.kitchenId == request.auth.uid ||
        ('riderId' in resource.data && resource.data.riderId == request.auth.uid) ||
        ('riderId' in request.resource.data && request.resource.data.riderId == request.auth.uid) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Riders: any auth user can read; rider writes own doc; admin manages all
    match /riders/{riderId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == riderId;
      allow update: if request.auth != null && (request.auth.uid == riderId || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
